<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="ir_cron_sync_shopify_products" model="ir.cron">
            <field name="name">Shopify: Sync Products (Hourly)</field>
            <field name="model_id" ref="model_shopify_config"/>
            <field name="state">code</field>
            <field name="code">model.action_sync_products_cron()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            </record>

        <record id="ir_cron_sync_shopify_orders" model="ir.cron">
            <field name="name">Shopify: Import Orders (15 min)</field>
            <field name="model_id" ref="model_shopify_config"/>
            <field name="state">code</field>
            <field name="code">model.action_sync_orders_cron()</field>
            <field name="interval_number">15</field>
            <field name="interval_type">minutes</field>
            </record>
    </data>
</odoo>